# Copy to secrets.yaml and fill in. Generate API key and OTA password with:
# esphome run rotary-lightswitch.yaml  (will prompt to generate keys)

wifi_ssid: "Your WiFi SSID"
wifi_password: "Your WiFi password"
api_encryption_key: ""   # Leave empty on first run; ESPHome will generate
ota_password: ""        # Leave empty on first run; ESPHome will generate
ap_password: "fallback-ap-password"
